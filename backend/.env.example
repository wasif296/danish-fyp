NODE_ENV=development
PORT=5000
MONGO_URL=mongodb://localhost:27017/school-management
MONGODB_URI=
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
RESET_PASSWORD_SECRET=replace-with-a-separate-reset-secret
RESET_PASSWORD_EXPIRES_IN=15m
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,https://your-frontend.vercel.app,https://your-frontend.netlify.app
PASSWORD_RESET_URL=http://localhost:3000/reset-password
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM=no-reply@schoolmanagement.local
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=school-management-system
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change-this-password
SUPER_ADMIN_SCHOOL_NAME=Main Campus
